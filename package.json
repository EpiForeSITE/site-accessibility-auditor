{
	"name": "touch-target-auditor",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "node --test",
		"evaluate:compare": "node ./scripts/compare-benchmarks.mjs ./evaluation/benchmark/ground-truth.json ./evaluation/results",
		"evaluate:aggregate": "node ./scripts/aggregate-metrics.mjs ./evaluation/results",
		"lint": "prettier --check . && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"chrome-types": "^0.1.425",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.8"
	}
}
